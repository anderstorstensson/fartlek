#!/usr/bin/env python3
"""Loopback-only client for the running Fartlek API.

Exists for AI-coach sessions: permission allowlists match Bash commands by
prefix and break on colons, so a URL can never appear in an allow rule
(`Bash(curl http://127.0.0.1:8077/:*)` silently never matches). The safe rule
is `Bash(scripts/api:*)` with the origin pinned here in code instead — only
127.0.0.1 is reachable, and there are no flags to write files or follow
arbitrary URLs.

Usage:
    scripts/api GET "/api/activities?limit=50"
    scripts/api GET /api/activities/123
    scripts/api POST /api/notes '{"kind": "session", "title": "...", "content": "..."}'
    scripts/api POST /api/plan - < plan.json      # body "-" reads stdin
"""

import os
import sys
import urllib.error
import urllib.request


def main() -> int:
    if len(sys.argv) < 3:
        print(__doc__, file=sys.stderr)
        return 2
    method = sys.argv[1].upper()
    path = sys.argv[2]
    if not path.startswith("/"):
        print("error: path must start with '/' — this client only reaches the local API",
              file=sys.stderr)
        return 2

    body = None
    if len(sys.argv) > 3:
        raw = sys.stdin.read() if sys.argv[3] == "-" else sys.argv[3]
        body = raw.encode("utf-8")

    port = os.environ.get("FARTLEK_PORT", "8077")
    request = urllib.request.Request(
        f"http://127.0.0.1:{port}{path}",
        data=body,
        method=method,
        headers={"Content-Type": "application/json"} if body is not None else {},
    )
    try:
        with urllib.request.urlopen(request, timeout=60) as response:
            sys.stdout.write(response.read().decode("utf-8"))
            sys.stdout.write("\n")
    except urllib.error.HTTPError as error:
        sys.stderr.write(f"{error.code} {error.reason}: {error.read().decode('utf-8')}\n")
        return 1
    except urllib.error.URLError as error:
        sys.stderr.write(f"error: {error.reason} — is the app running on port {port}?\n")
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
