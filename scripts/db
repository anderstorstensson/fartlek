#!/usr/bin/env python3
"""Read-only SQL against the Fartlek database — no sqlite3 CLI required.

Exists for AI-coach sessions: the sqlite3 binary may not be installed, and
permission allowlists can't express "read-only sqlite3" reliably anyway. This
opens the DB with mode=ro *and* PRAGMA query_only, so every write statement
fails at the SQLite level regardless of the SQL passed in.

Rows print tab-separated with a header line.

Usage:
    scripts/db "SELECT id, name, distance_m FROM activities ORDER BY start_time_local DESC LIMIT 5"
    scripts/db - < query.sql      # SQL "-" reads stdin
"""

import os
import sqlite3
import sys
from pathlib import Path


def main() -> int:
    if len(sys.argv) != 2:
        print(__doc__, file=sys.stderr)
        return 2
    sql = sys.stdin.read() if sys.argv[1] == "-" else sys.argv[1]

    base_dir = Path(__file__).resolve().parent.parent
    data_dir = Path(os.environ.get("FARTLEK_DATA_DIR", base_dir / "data"))
    db_path = data_dir / "fartlek.sqlite3"
    if not db_path.exists():
        sys.stderr.write(f"error: no database at {db_path}\n")
        return 1

    try:
        connection = sqlite3.connect(f"file:{db_path.as_posix()}?mode=ro", uri=True)
        connection.execute("PRAGMA query_only = 1")
        cursor = connection.execute(sql)
        if cursor.description:
            print("\t".join(column[0] for column in cursor.description))
        for row in cursor:
            print("\t".join("" if value is None else str(value) for value in row))
    except sqlite3.Error as error:
        sys.stderr.write(f"sqlite error: {error}\n")
        return 1
    return 0


if __name__ == "__main__":
    sys.exit(main())
